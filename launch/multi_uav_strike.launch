<?xml version="1.0"?>
<launch>
  <node name="target_motion_simulator_node"
        pkg="multi_uav_strike"
        type="target_motion_simulator_node"
        output="screen"
        respawn="false">
      <!-- 核心参数配置（所有参数均显式声明，方便修改） -->
      <!-- 初始位置 -->
      <param name="x_init" value="0.0" type="double" />
      <param name="y_init" value="5.0" type="double" />
      <!-- 速度限制（m/s） -->
      <param name="max_speed" value="0.1" type="double" />
      <param name="min_speed" value="0.0" type="double" />
      <!-- 加速度限制（m/s²） -->
      <param name="max_tangential_acc" value="1" type="double" />
      <param name="max_normal_acc" value="0.1" type="double" />
      <!-- 频率配置（Hz） -->
      <param name="sim_freq" value="100.0" type="double" />
      <param name="trigger_freq" value="0.1" type="double" />
  </node>

  <group ns="quad1">
    <node name="quad" pkg="multimodequad_ros" type="multimodequad_ros" respawn="true" output="screen">
      <param name="init_pose_x"   value="0.0"/>
      <param name="init_pose_y"   value="0.0"/>
      <param name="init_pose_z"   value="-5.0"/>
    </node>
    <node name="gimbal_simulator_node"
        pkg="multi_uav_strike"
        type="gimbal_simulator_node"
        output="screen"
        respawn="false">
      <param name="image_width" value="1920" type="int" />
      <param name="image_height" value="1080" type="int" />
      <param name="fov_deg" value="45.0" type="double" />
      <param name="gimbal_p_gain" value="1.5" type="double" />
      <param name="max_yaw_rate" value="1.2" type="double" />
      <param name="max_pitch_rate" value="1.2" type="double" />
      <param name="uav_pose_topic" value="/uav_pose" type="string" />
      <param name="loop_freq" value="100.0" type="double" />
      <param name="image_noise_std_dev" value="0.1" type="double" />
    </node>
    <node name="target_estimator_node"
          pkg="multi_uav_strike"
          type="target_estimator_node"
          output="screen"
          respawn="false">
        <param name="num_particles" value="500" type="int" />
        <param name="init_dist_std_dev" value="1.0" type="double" />
        <param name="process_noise_std_dev" value="0.2" type="double" />
        <param name="observation_noise_std_dev" value="0.05" type="double" />
        <param name="min_confidence" value="0.2" type="double" />
        <param name="pf_loop_freq" value="50.0" type="double" />
        <param name="vel_consistency_weight" value="0.3" type="double" />
        <param name="target_z_prior" value="0.0" type="double" />
        <param name="target_z_weight" value="0.1" type="double" />
        <param name="angle_error_dist_gain" value="0.03" type="double" />
        <param name="est_marker_r" value="1.0" type="double" />
        <param name="est_marker_g" value="1.0" type="double" />
        <param name="est_marker_b" value="0.0" type="double" />
        <param name="est_marker_a" value="1.0" type="double" />
    </node>
    <!--<node name="guidance_control_node"
          pkg="multi_uav_strike"
          type="guidance_control_node"
          output="screen"
          respawn="false">
        <param name="guidance_strategy" value="intercept" type="str" />
        <param name="uav_speed" value="10.0" type="double" />
        <param name="intercept_time_horizon" value="5.0" type="double" />
        <param name="v_max" value="5.0" type="double" />
        <param name="a_max" value="10.0" type="double" />
        <param name="pos_p_gain" value="1.0" type="double" />
        <param name="vel_p_gain" value="0.5" type="double" />
        <param name="thrust_weight" value="0.5" type="double" />
        <param name="los_kp_yaw" value="1.5" type="double" />
        <param name="los_kp_pitch" value="1.5" type="double" />
        <param name="los_max_rate" value="1.2" type="double" />
    </node>-->
  </group>

  <group ns="quad2">
    <!--node name="quad" pkg="multimodequad_ros" type="multimodequad_ros" respawn="true" output="screen">
      <param name="init_pose_x"   value="2.0"/>
      <param name="init_pose_y"   value="50.0"/>
      <param name="init_pose_z"   value="-50.0"/>
    </node-->
    <node name="gimbal_simulator_node"
        pkg="multi_uav_strike"
        type="gimbal_simulator_node"
        output="screen"
        respawn="false">
      <param name="image_width" value="1920" type="int" />
      <param name="image_height" value="1080" type="int" />
      <param name="fov_deg" value="45.0" type="double" />
      <param name="gimbal_p_gain" value="1.5" type="double" />
      <param name="max_yaw_rate" value="1.2" type="double" />
      <param name="max_pitch_rate" value="1.2" type="double" />
      <param name="uav_pose_topic" value="/uav_pose" type="string" />
      <param name="loop_freq" value="100.0" type="double" />
      <param name="image_noise_std_dev" value="0.1" type="double" />
    </node>
    <node name="target_estimator_node"
          pkg="multi_uav_strike"
          type="target_estimator_node"
          output="screen"
          respawn="false">
        <param name="num_particles" value="500" type="int" />
        <param name="init_dist_std_dev" value="1.0" type="double" />
        <param name="process_noise_std_dev" value="0.2" type="double" />
        <param name="observation_noise_std_dev" value="0.1" type="double" />
        <param name="min_confidence" value="0.2" type="double" />
        <param name="pf_loop_freq" value="50.0" type="double" />
        <param name="vel_consistency_weight" value="0.3" type="double" />
        <param name="target_z_prior" value="0.0" type="double" />
        <param name="target_z_weight" value="0.1" type="double" />
        <param name="angle_error_dist_gain" value="0.03" type="double" />
        <param name="est_marker_r" value="0.0" type="double" />
        <param name="est_marker_g" value="1.0" type="double" />
        <param name="est_marker_b" value="0.0" type="double" />
        <param name="est_marker_a" value="1.0" type="double" />
    </node>
    <node name="guidance_control_node"
          pkg="multi_uav_strike"
          type="guidance_control_node"
          output="screen"
          respawn="false">
        <param name="guidance_strategy" value="los" type="str" />
        <param name="uav_speed" value="10.0" type="double" />
        <param name="intercept_time_horizon" value="5.0" type="double" />
        <param name="v_max" value="5.0" type="double" />
        <param name="a_max" value="10.0" type="double" />
        <param name="pos_p_gain" value="1.0" type="double" />
        <param name="vel_p_gain" value="0.5" type="double" />
        <param name="thrust_weight" value="0.5" type="double" />
        <param name="los_kp_yaw" value="1.5" type="double" />
        <param name="los_kp_pitch" value="1.5" type="double" />
        <param name="los_max_rate" value="1.2" type="double" />
        <param name="los_debug_yaw_only" value="true" type="bool" />       <!-- 只控制偏航 -->
        <param name="los_debug_fixed_thrust" value="true" type="bool" />   <!-- 使用固定油门 -->
        <param name="los_debug_fixed_thrust_value" value="0.313" type="double" />  <!-- 固定油门值 -->
    </node>
  </group>

  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find multi_uav_strike)/rviz/view_strike.rviz" />
</launch>