<?xml version="1.0"?>
<launch>
    <!-- 目标运动模拟节点启动配置 -->
    <node name="target_motion_simulator_node" 
          pkg="multi_uav_strike" 
          type="target_motion_simulator_node" 
          output="screen" 
          respawn="false"> <!-- respawn=false：节点退出后不自动重启 -->

        <!-- 核心参数配置（所有参数均显式声明，方便修改） -->
        <!-- 初始位置 -->
        <param name="x_init" value="2.0" type="double" />
        <param name="y_init" value="2.0" type="double" />
        <!-- 速度限制（m/s） -->
        <param name="max_speed" value="2.0" type="double" />
        <param name="min_speed" value="0.0001" type="double" />
        <!-- 加速度限制（m/s²） -->
        <param name="max_tangential_acc" value="2.0" type="double" />
        <param name="max_normal_acc" value="1.0" type="double" />
        <!-- 频率配置（Hz） -->
        <param name="sim_freq" value="100.0" type="double" /> <!-- 100Hz主仿真循环 -->
        <param name="trigger_freq" value="0.1" type="double" /> <!-- 0.1Hz加减速触发 -->

    </node>

    <!-- 可选：启动ROS话题查看工具（如需实时监控，取消注释即可） -->
    <!--
    <node name="topic_echo" 
          pkg="rostopic" 
          type="rostopic" 
          args="echo /target_position -n 100" 
          output="screen" />
    -->
</launch>