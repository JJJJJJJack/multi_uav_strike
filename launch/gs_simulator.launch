<?xml version="1.0"?>
<!--
  gs_simulator.launch
  地面站模拟器 - 用于仿真测试

  功能：
  - 发布初始工作模式（SEARCH_ONLY / SEARCH_TRACK / SEARCH_STRIKE）
  - 发布测试航点列表

  使用方法：
  $ roslaunch multi_uav_strike gs_simulator.launch mode:=SEARCH_STRIKE
-->
<launch>
  <!-- 默认参数 -->
  <arg name="mode" default="SEARCH_ONLY" />
  <arg name="uav_name" default="uav0" />

  <!-- ============================================================ -->
  <!-- 工作模式发布器 -->
  <!-- ============================================================ -->
  <node name="gs_mode_publisher"
        pkg="rostopic"
        type="rostopic"
        args="pub /gs/mode_cmd std_msgs/String '{data: $(arg mode)}' -r 1"
        output="screen"
        respawn="true" />

  <!-- ============================================================ -->
  <!-- 测试航点列表发布器 -->
  <!-- 发布一个简单的方形航线 -->
  <!-- ============================================================ -->
  <node name="gs_waypoint_publisher"
        pkg="rostopic"
        type="rostopic"
        args="pub /gs/waypoint_upload nav_msgs/Path '{header: {stamp: now, frame_id: map}, poses: []}' -r 1"
        output="screen"
        respawn="true" />

</launch>
